# ===========================================================================
# 环境变量模板。复制本文件为 .env.local 后填入实际值。
# 任何带 NEXT_PUBLIC_ 前缀的变量都会暴露到前端，不要放敏感值。
# ===========================================================================

# ---------- 第一阶段（本地静态版）不需要任何 key 即可运行 ----------
# 你现在跑 `npm install && npm run dev` 就能看到首页 → 联合测试 → 成长档案。

# ---------- 第二阶段（接 LLM 后）填这一块 ----------
# LLM Provider 抽象：默认 DeepSeek，可改为 GLM / Anthropic / OpenAI。
# 切 provider 只改这 4 行，代码不用动（因为我们用 OpenAI 兼容 API）。

LLM_PROVIDER=deepseek
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat

# 如果换 GLM (智谱清言)：
# LLM_PROVIDER=glm
# LLM_API_KEY=
# LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# LLM_MODEL=glm-4-plus

# 如果换 Anthropic Claude：
# LLM_PROVIDER=anthropic
# LLM_API_KEY=
# LLM_BASE_URL=https://api.anthropic.com
# LLM_MODEL=claude-sonnet-4-5

# 如果换 OpenAI：
# LLM_PROVIDER=openai
# LLM_API_KEY=
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o

# ---------- 第二阶段（接 Supabase 后）填这一块 ----------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---------- 第二阶段（接 AI HOT 后）填这一块 ----------
AIHOT_BASE_URL=https://aihot.virxact.com

# ---------- 可选：LangSmith 追踪（调 LangGraph 出错时方便) ----------
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
